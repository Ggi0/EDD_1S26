graph GRAFO {
    rankdir=LR;
    node [
        shape=ellipse,
        style=filled,
        fillcolor="#B0C4DE",
        fontname="Arial",
        fontsize=12
    ];
    edge [
        color="#555555"
    ];

    "1";
    "2";
    "3";
    "4";

    "1" -- "2";
    "1" -- "3";
    "2" -- "4";
    "3" -- "4";
}
