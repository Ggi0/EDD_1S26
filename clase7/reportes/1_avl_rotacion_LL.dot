digraph AVL {
    rankdir=TB;
    node [
        shape=circle,
        style=filled,
        fontname="Arial Bold",
        fontsize=11
    ];

    edge [fontname="Arial", fontsize=9, color="#546E7A"];

    n20 [label="20\nh=1  fe=0", fillcolor="#A5D6A7"];
    n10 [label="10\nh=0  fe=0", fillcolor="#A5D6A7"];
    n30 [label="30\nh=0  fe=0", fillcolor="#A5D6A7"];
    n20 -> n10 [label=""];
    n20 -> n30 [label=""];
}
