digraph BST {
    rankdir=TB;
    node [
        shape=circle,
        style=filled,
        fillcolor="#B0BEC5",
        fontname="Arial"
    ];

    n20 [label="20"];
    n10 [label="10"];
    n40 [label="40"];
    n30 [label="30"];
    n25 [label="25"];
    n50 [label="50"];
    n20 -> n10;
    n20 -> n40;
    n40 -> n30;
    n30 -> n25;
    n40 -> n50;
}
