digraph BTree {
    rankdir=TB;
    splines=false;
    nodesep=0.4;
    ranksep=1.2;
    ordering=out;
    node [
        shape=record,
        style=filled,
        fontname="Arial",
        fontsize=12,
        height=0.45
    ];

    edge [color="#111111", arrowhead=none, penwidth=1.3];

    label="Arbol B  -  Orden M=3  -  Claves totales=5";
    labelloc=top;
    fontsize=13;

    n0 [label="<p0>| 15 |<p1>| 30 |<p2>", fillcolor="#BDBDBD"];
    n1 [label=" 5 ", fillcolor="#FFFFFF"];
    n0:p0 -> n1;
    n2 [label=" 25 ", fillcolor="#FFFFFF"];
    n0:p1 -> n2;
    n3 [label=" 35 ", fillcolor="#FFFFFF"];
    n0:p2 -> n3;
}
