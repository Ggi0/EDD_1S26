digraph BTree {
    rankdir=TB;
    splines=false;
    nodesep=0.4;
    ranksep=1.2;
    ordering=out;
    node [
        shape=record,
        style=filled,
        fontname="Arial",
        fontsize=12,
        height=0.45
    ];

    edge [color="#111111", arrowhead=none, penwidth=1.3];

    label="Arbol B  -  Orden M=5  -  Claves totales=16";
    labelloc=top;
    fontsize=13;

    n0 [label="<p0>| 17 |<p1>| 45 |<p2>| 59 |<p3>| 80 |<p4>", fillcolor="#BDBDBD"];
    n1 [label=" 1  |  3  |  10 ", fillcolor="#FFFFFF"];
    n0:p0 -> n1;
    n2 [label=" 24  |  31  |  38 ", fillcolor="#FFFFFF"];
    n0:p1 -> n2;
    n3 [label=" 53  |  54 ", fillcolor="#FFFFFF"];
    n0:p2 -> n3;
    n4 [label=" 66  |  73 ", fillcolor="#FFFFFF"];
    n0:p3 -> n4;
    n5 [label=" 87  |  94 ", fillcolor="#FFFFFF"];
    n0:p4 -> n5;
}
